#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

mode="${1:---cached}"
current_user="${USER:-}"
if [ -z "$current_user" ]; then
  current_user="$(id -un 2>/dev/null || true)"
fi

local_password=""
clickhouse_config="MT5Research/Config/clickhouse.json"
if [ -f "$clickhouse_config" ]; then
  local_password="$(
    sed -n 's/.*"password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$clickhouse_config" | head -n 1
  )"
fi
if [ "$local_password" = "null" ]; then
  local_password=""
fi

run_grep() {
  scan_mode="$1"
  pattern_mode="$2"
  pattern="$3"
  ref="${4:-}"

  if [ "$scan_mode" = "--cached" ]; then
    git grep --cached -I -l "$pattern_mode" -- "$pattern" -- . 2>/dev/null || true
  else
    git grep -I -l "$pattern_mode" -- "$pattern" "$ref" -- . 2>/dev/null || true
  fi
}

scan_ref() {
  scan_mode="$1"
  ref="${2:-}"
  failed=0

  if [ -n "$local_password" ]; then
    files="$(run_grep "$scan_mode" -F "$local_password" "$ref")"
    if [ -n "$files" ]; then
      printf '%s\n' "[git-guard] Refusing Git operation: local ClickHouse password (<masked>) appears in tracked content:"
      printf '%s\n' "$files"
      failed=1
    fi
  fi

  files="$(run_grep "$scan_mode" -E '"password"[[:space:]]*:[[:space:]]*"[^"]+"' "$ref")"
  if [ -n "$files" ]; then
    printf '%s\n' "[git-guard] Refusing Git operation: tracked JSON appears to contain a non-null password field:"
    printf '%s\n' "$files"
    failed=1
  fi

  if [ -n "$current_user" ]; then
    files="$(run_grep "$scan_mode" -F "/Users/$current_user" "$ref")"
    if [ -n "$files" ]; then
      printf '%s\n' "[git-guard] Refusing Git operation: tracked content contains a personal absolute macOS path. Use a relative path instead:"
      printf '%s\n' "$files"
      failed=1
    fi

    files="$(run_grep "$scan_mode" -F "\\$current_user\\" "$ref")"
    if [ -n "$files" ]; then
      printf '%s\n' "[git-guard] Refusing Git operation: tracked content contains a personal backslash path. Use a relative path instead:"
      printf '%s\n' "$files"
      failed=1
    fi
  fi

  return "$failed"
}

case "$mode" in
  --cached)
    scan_ref --cached
    ;;
  --ref)
    ref="${2:-HEAD}"
    scan_ref --ref "$ref"
    ;;
  *)
    printf '%s\n' "usage: .githooks/secret-path-guard [--cached|--ref <git-ref>]" >&2
    exit 2
    ;;
esac
